# 이 파일을 복사해 .env 를 만들고 값을 채우세요: cp .env.example .env
# 아래 값들은 모두 페이지 소스에 노출되는 "공개" 정보입니다(비밀키 아님).

# 사이트 정식 URL (배포 도메인). sitemap·canonical·RSS 절대경로에 사용됩니다.
PUBLIC_SITE_URL=https://example.com

# Google AdSense 게시자 ID (예: ca-pub-0000000000000000). 비워두면 광고가 로드되지 않습니다.
PUBLIC_ADSENSE_CLIENT=

# 본문 하단 광고 단위 슬롯 ID (AdSense에서 광고 단위 생성 후 발급)
PUBLIC_ADSENSE_SLOT_ARTICLE=

# Google Search Console 소유 확인 코드 (HTML 태그 방식 content 값)
PUBLIC_GOOGLE_SITE_VERIFICATION=

# 네이버 서치어드바이저 소유 확인 코드
PUBLIC_NAVER_SITE_VERIFICATION=
