---
import type { HTMLAttributes } from 'astro/types';
import { withBase } from '../utils/url';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const cleanBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(cleanBase, '') || '/';
const subpath = pathname.match(/[^\/]+/g);
const isActive = href === pathname || href === '/' + (subpath?.[0] || '');
const finalHref = withBase(typeof href === 'string' ? href : '/');
---

<a href={finalHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
