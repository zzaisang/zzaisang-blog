---
import { SOCIAL_LINKS } from '../consts';

interface Props {
	variant?: 'header' | 'footer';
}

const { variant = 'header' } = Astro.props;

// 아이콘별 SVG path. viewBox 가 아이콘마다 달라 함께 보관합니다.
const ICONS: Record<string, { viewBox: string; path: string }> = {
	github: {
		viewBox: '0 0 16 16',
		path: 'M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z',
	},
	linkedin: {
		viewBox: '0 0 24 24',
		path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
	},
	email: {
		viewBox: '0 0 24 24',
		path: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z',
	},
	x: {
		viewBox: '0 0 24 24',
		path: 'M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z',
	},
};

// href 와 등록된 아이콘이 모두 있는 항목만 노출합니다.
const links = SOCIAL_LINKS.filter((link) => link.href && ICONS[link.icon]);
---

{
	links.length > 0 && (
		<div class:list={['social-links', variant]}>
			{links.map((link) => {
				const icon = ICONS[link.icon];
				const isMail = link.href.startsWith('mailto:');
				return (
					<a
						href={link.href}
						target={isMail ? undefined : '_blank'}
						rel={isMail ? undefined : 'noopener noreferrer'}
					>
						<span class="sr-only">{link.name}</span>
						<svg viewBox={icon.viewBox} aria-hidden="true" width="32" height="32">
							<path fill="currentColor" d={icon.path} />
						</svg>
					</a>
				);
			})}
		</div>
	)
}

<style>
	.social-links {
		display: flex;
	}
	.social-links a {
		display: flex;
		color: var(--black);
	}
	.social-links.footer {
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links.footer a {
		color: rgb(var(--gray));
	}
	.social-links.footer a:hover {
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 720px) {
		.social-links.header {
			display: none;
		}
	}
</style>
